# Microsoft Entra ID (Azure AD) — Wireservers app registration
# Vars must be prefixed EXPO_PUBLIC_ to be inlined into the web bundle.
# Copy this file to .env (or .env.local) and fill in real values.

# Application (client) ID from the Wireservers app registration
EXPO_PUBLIC_MSAL_CLIENT_ID=""

# Directory (tenant) ID — or "common" / "organizations" for multi-tenant
EXPO_PUBLIC_MSAL_TENANT_ID=""

# Where Entra redirects after login. Must be registered as a SPA
# redirect URI in the app registration. Defaults to window.location.origin
# at runtime if left blank.
EXPO_PUBLIC_MSAL_REDIRECT_URI=""

# Optional: where to land after logout. Defaults to redirect URI.
EXPO_PUBLIC_MSAL_POST_LOGOUT_REDIRECT_URI=""
