# Enforce LF for all files on checkout to prevent CRLF breaking npx/Node shebang on Unix/macOS
* text=auto eol=lf

# Explicitly force LF for scripts and source files
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
bin/*  text eol=lf
